# ── Copy this file to .env and fill in your own values ──────────────────────
# Never commit .env — it is in .gitignore

# ── LLM (required) ───────────────────────────────────────────────────────────
# Get a free key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional — only needed if LLM_PROVIDER=claude
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── Database (required) ───────────────────────────────────────────────────────
# Local dev: uses docker-compose postgres, no change needed
# Production: get a free Neon DB at https://neon.tech
DATABASE_URL=postgresql://dev_user:dev_password_local_only@localhost:5432/portfolio_ai

# ── Free data APIs ────────────────────────────────────────────────────────────
# https://newsapi.org — free tier: 100 req/day
NEWS_API_KEY=

# https://www.alphavantage.co/support/#api-key — free tier: 25 req/day
ALPHA_VANTAGE_KEY=

# https://console.cloud.google.com → YouTube Data API v3 → Create API Key
YOUTUBE_API_KEY=

# https://fred.stlouisfed.org/docs/api/api_key.html — free, no limits
FRED_API_KEY=

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=

# Generate with: openssl rand -hex 32
SCHEDULER_SECRET=

# ── Zerodha / Kite (optional — only for Indian stock portfolio sync) ──────────
# Register a Kite Connect app at https://kite.zerodha.com/developers
# Set redirect URL to: http://localhost:8080/admin/zerodha/callback (local)
#                  or: https://your-api.onrender.com/admin/zerodha/callback (prod)
ZERODHA_API_KEY=
ZERODHA_API_SECRET=

# ── Config ────────────────────────────────────────────────────────────────────
SECRETS_SOURCE=env          # "env" locally, "gcp" on Cloud Run
LLM_PROVIDER=gemini         # "gemini" (free) or "claude" (paid, better quality)
LOG_LEVEL=INFO              # DEBUG for local dev
